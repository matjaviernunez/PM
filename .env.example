# Copia este archivo a .env y completa los valores reales.
# El .env NO se sube a git (está en .gitignore).

# Clave secreta de Flask. Genera una propia y única, por ejemplo:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=pon-aqui-una-clave-larga-y-aleatoria

# DEBUG debe ser false en producción (true solo en desarrollo local).
DEBUG=false

ADMIN_EMAIL=javier.ns87@gmail.com
